                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "J2LM7",
                      "name": "modalBio",
                      "fill": "$color-charcoal",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Shamir came to Kabbalah after 15 years as a mechanical engineer in Mumbai. He moved to Israel in 2012 to study directly under Rav Laitman, and has been one of the key teachers leading the Indian programs since 2018.",
                      "lineHeight": 1.65,
                      "fontFamily": "$font-body-en",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "GCQ64",
                      "name": "modalBioHi",
                      "fill": "$color-charcoal-70",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "शमीर मुंबई में 15 साल इंजीनियर रहे, फिर 2012 में सीधे रब लैटमैन के पास इज़राइल चले गए। 2018 से वे भारत के कार्यक्रमों के मुख्य शिक्षकों में से एक हैं।",
                      "lineHeight": 1.7,
                      "fontFamily": "$font-body-hi",
                      "fontSize": 13,
                      "fontWeight": "normal"
