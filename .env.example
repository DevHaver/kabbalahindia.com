# ----------------------------------------------------------------------------
# Kabbalah Academy India — environment configuration
# Copy this file to `.env` for local dev, and set these in your host's
# secret store for prod. Names are prefixed `NUXT_` so Nuxt's runtimeConfig
# auto-binds them.
# ----------------------------------------------------------------------------

# ---- Telegram notification (recommended — 5 min setup) --------------------
# Get the bot token from @BotFather (Telegram → /newbot).
# Then message your new bot once and read your chat_id from:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Both must be set, or Telegram is skipped.
NUXT_TELEGRAM_BOT_TOKEN=
NUXT_TELEGRAM_CHAT_ID=

# ---- Generic webhook (optional — for n8n/Make/Zapier/Discord/your own) ----
# Receives every accepted signup as JSON. Fires alongside Telegram if both set.
# Examples:
#   - Discord channel webhook:   https://discord.com/api/webhooks/...
#   - n8n / Make / Zapier hook:  https://hook.eu1.make.com/...
#   - Your own backend:          https://your.api/signup
NUXT_SIGNUP_WEBHOOK_URL=

# Optional shared secret sent as `Authorization: Bearer <token>` so your
# webhook receiver can verify the call originated here. Leave blank to skip.
NUXT_SIGNUP_WEBHOOK_TOKEN=

# ---- WhatsApp destination URL ---------------------------------------------
# Used by the floating WhatsApp bar, footer icon, and the "Or open WhatsApp
# directly" link below the signup form. Accepts either shape:
#   - Group invite:  https://chat.whatsapp.com/XXXXXXXXXX
#   - 1:1 deep link: https://wa.me/919876543210
NUXT_PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/placeholder
